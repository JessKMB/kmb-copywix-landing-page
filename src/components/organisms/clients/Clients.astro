---
import BackgroundVideo from '../../../assets/clients/background.mp4';
import Title from '../../atoms/title/Title.astro';


interface Props {
    text:{
        instituciones:string,
        cooperativas:string;
        mutualistas:string;
        bancos:string;
    }
}

const {text} = Astro.props

---

<section class="clients" id="Clientes">
    <video id="background-video" loop  autoplay muted  playsinline>
        <source src={BackgroundVideo} type="video/mp4"/>
        <p>Tu navegador no soporta videos.</p>
    </video>
    <div class="clients__content">
        
        <div class="clients__content__child">
            <Title level={3} color='white' size='xxxxxxl'>Nuestros <br/> Clientes</Title>
        </div>
        
        <div class="clients__content__child">
            <div class="clients__content__child__item">
                <Title level={3} color='white' size='xxxxxxl'>{text.instituciones}</Title>
                <div class="divider"></div>
                <Title level={4} color='white' size="xxxl">INSTITUCIONES</Title>
            </div>
            <div class="clients__content__child__item">
                <Title level={3} color='white' size='xxxxxxl'>{text.cooperativas}</Title>
                <div class="divider"></div>
                <Title level={4} color='white' size="xxxl">COOPERATIVAS</Title>
            </div>
            <div class="clients__content__child__item">
                <Title level={3} color='white' size='xxxxxxl'>{text.mutualistas}</Title>
                <div class="divider"></div>
                <Title level={4} color='white' size="xxxl">MUTUALISTAS</Title>
            </div>
            <div class="clients__content__child__item">
                <Title level={3} color='white' size='xxxxxxl'>{text.bancos}</Title>
                <div class="divider"></div>
                <Title level={4} color='white' size="xxxl">BANCOS</Title>
            </div>
        </div>
    
    </div>
</section>

<style>
    
    .clients {
        padding: 100px 0px;
        position: relative;
        width: 100vw;
        background-color: rgba(0, 0, 0, 0.356);
    }
    #background-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
    }

    .clients__content {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
        width: 100%;
        flex-wrap: wrap;
    }
    .clients__content__child{
        padding: 0px 20px;
        flex: 1 1 400px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        gap: 40px;
    }
    .divider{
        width: 100%;
        height: 2px;
        background-color: var(--color-white);
    }
    .clients__content__child__item{
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

</style>